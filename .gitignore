# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/**/Binaries/*
MyProject/Binaries/**

# Builds
Build/*
MyProject/Build/**

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*
MyProject/Saved/**

# Compiled source files for the engine to use
Intermediate/*
Plugins/**/Intermediate/*
MyProject/Intermediate/**

# Cache files for the editor to use
DerivedDataCache/*
MyProject/DerivedDataCache/**

# Local Unreal vault/sample cache and imported cache artifacts
MyProject/Content/Blueprints/VaultCache/**
MyProject/Content/GameAnimationSample/**
MyProject/Content/Characters/Echo/**
MyProject/Content/Characters/Paragon/**
MyProject/Content/Characters/UE4_Mannequin/**
MyProject/Content/Characters/UE5_Mannequins/**
MyProject/Content/Characters/UEFN_Mannequin/**
MyProject/Content/MetaHumans/**
MyProject/Content/Locomotor/**
MyProject/Content/**/DerivedDataCache/**

